    "profile.delete.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف حساب Workout Cloud وبيانات الملف الشخصي على الخادم. ستبقى بيانات التمرين المحلية على هذا iPhone حتى تعيد تعيين قاعدة البيانات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Damit loeschst du deinen Workout-Cloud-Account und alle serverseitigen Profildaten. Lokale Trainingsdaten auf diesem iPhone bleiben bestehen, bis du die Datenbank zuruecksetzt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This removes your Workout Cloud account and server-side profile data. Local workout data on this iPhone remains until you reset the database."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina tu cuenta de Workout Cloud y tus datos de perfil del servidor. Los datos locales del iPhone se quedan hasta que restablezcas la base de datos."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह आपके Workout Cloud अकाउंट और सर्वर प्रोफाइल डेटा को हटा देगा। इस iPhone का लोकल वर्कआउट डेटा तब तक रहेगा जब तक आप डेटाबेस रीसेट नहीं करते।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这会删除你的 Workout Cloud 账号和服务器端资料数据。本机训练数据会保留，直到你重置数据库。"
          }
        }
      }
    },
